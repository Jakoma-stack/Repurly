# Repurly environment reference
# Copy to .env.local for local development and fill with real values.
# This file reflects the current Next.js + Clerk + Stripe + Postgres + Inngest build.

# -----------------------------------------------------------------------------
# Core app
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@localhost:5432/repurly
TOKEN_ENCRYPTION_SECRET=replace-with-at-least-32-random-characters

# -----------------------------------------------------------------------------
# Authentication (Clerk)
# -----------------------------------------------------------------------------
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Billing (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# -----------------------------------------------------------------------------
# Email / notifications (Resend + ops alerts)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Repurly <noreply@example.com>"
ALERT_EMAIL_TO=
ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Background workflows (Inngest)
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
PUBLISH_DUE_BATCH_SIZE=25
PUBLISH_DISPATCH_THROTTLE_MS=120000
RECONNECT_WARNING_DAYS=7
ENABLE_LIVE_USAGE_METERING=false

# -----------------------------------------------------------------------------
# Storage (S3 / R2 compatible)
# -----------------------------------------------------------------------------
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# AI drafting / reply generation
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# LinkedIn (current primary launch channel)
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
LINKEDIN_SCOPE=openid profile email w_member_social w_organization_social
LINKEDIN_API_TIMEOUT_MS=15000
LINKEDIN_OAUTH_TIMEOUT_MS=15000
LINKEDIN_PUBLISH_TIMEOUT_MS=25000

# -----------------------------------------------------------------------------
# X
# -----------------------------------------------------------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/x/callback
X_SCOPE=tweet.read tweet.write users.read offline.access media.write
X_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Meta (Facebook Pages / Instagram Business)
# -----------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/facebook/callback
FACEBOOK_SCOPE=pages_show_list pages_manage_posts pages_read_engagement business_management
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback
INSTAGRAM_SCOPE=instagram_basic instagram_content_publish pages_show_list business_management
META_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_STATUS_MAX_POLLS=12
INSTAGRAM_STATUS_POLL_INTERVAL_MS=5000

# -----------------------------------------------------------------------------
# YouTube webhooks (future-facing)
# -----------------------------------------------------------------------------
YOUTUBE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
