# Billing
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / notifications
RESEND_API_KEY=
FROM_EMAIL=noreply@example.com
SLACK_WEBHOOK_URL=

# Queue / jobs
UPSTASH_REDIS_REST_URL=
