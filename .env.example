# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/repurly

# Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
